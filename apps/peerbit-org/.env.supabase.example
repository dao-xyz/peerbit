# Copy to `apps/peerbit-org/.env.supabase` (this file is gitignored)
#
# This file is meant to contain everything needed to:
# - deploy Supabase Edge Functions
# - apply Supabase migrations
# - set Supabase function secrets
# - run the site locally with working Updates subscriptions
#
# ---- Supabase project (CLI / admin) ----
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_DB_PASSWORD=your-db-password

# Used by Edge Functions.
# Note: `SUPABASE_*` names are reserved and already available in Edge Functions (the CLI will skip setting them as secrets).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Email provider (Resend) ----
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM="Peerbit <updates@peerbit.org>"

# ---- Site / Updates settings ----
SITE_URL=https://peerbit.org
UPDATES_ALLOWED_ORIGINS=https://peerbit.org,http://localhost:5173
UPDATES_SYNC_SECRET=replace-with-a-long-random-string

# Optional tuning
UPDATES_CONFIRM_TTL_MINUTES=1440
UPDATES_CONFIRM_THROTTLE_MINUTES=5

# ---- Managed Peerchecker DNS leases ----
# Cloudflare credentials belong only in the narrow Worker broker, never Supabase.
DNS_LEASE_DNS_BROKER_URL=https://peerbit-dns-lease-broker.your-account.workers.dev
# The same independently generated 32-byte base64url secret is stored in the
# Worker as BROKER_SHARED_SECRET.
DNS_LEASE_DNS_BROKER_SECRET=replace-with-43-character-base64url
# Used to derive recoverable, single-use proof tokens. Do not rotate while a
# pending claim or renewal challenge is live.
DNS_LEASE_CHALLENGE_SECRET=replace-with-43-character-base64url
# A separate random 32+ byte bearer secret used only by scheduled cleanup.
DNS_LEASE_CLEANUP_SECRET=replace-with-a-long-random-secret

# Optional tuning
DNS_LEASE_PENDING_TTL_SECONDS=600
DNS_LEASE_ACTIVE_TTL_SECONDS=86400
DNS_LEASE_RECORD_TTL_SECONDS=300
DNS_LEASE_CHALLENGE_TIMEOUT_MS=5000
DNS_LEASE_VERIFY_INTERVAL_SECONDS=30
DNS_LEASE_RENEW_INTERVAL_SECONDS=60
DNS_LEASE_RENEW_CHALLENGE_TTL_SECONDS=600
DNS_LEASE_BROKER_TIMEOUT_MS=40000
DNS_LEASE_PROVISIONING_LOCK_SECONDS=300
DNS_LEASE_CLEANUP_LOCK_SECONDS=180
DNS_LEASE_CLEANUP_QUARANTINE_FAILURES=12

# ---- Site (Vite) ----
# The subscribe dialog posts here. For local site dev, export this or copy it to `apps/peerbit-org/.env.local`.
VITE_UPDATES_EMAIL_FORM_ACTION=https://your-project-ref.supabase.co/functions/v1/updates-subscribe

{
	"name": "@peerbit/server",
	"version": "6.0.21",
	"author": "dao.xyz",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dao-xyz/peerbit.git",
		"directory": "packages/clients/peerbit-server/node"
	},
	"license": "Apache-2.0",
	"type": "module",
	"sideEffects": false,
	"bin": {
		"peerbit": "./dist/src/bin.js"
	},
	"module": "dist/src/index.js",
	"types": "dist/src/index.d.ts",
	"exports": {
		"import": "./dist/src/index.js"
	},
	"browser": {
		"./dist/src/server.js": "./dist/src/server.browser.js",
		"./server.js": "./dist/src/server.browser.js",
		"./dist/src/config.js": "./dist/src/config.browser.js",
		"./config.js": "./dist/src/config.browser.js",
		"./dist/src/remotes.js": "./dist/src/remotes.browser.js",
		"./remotes.js": "./dist/src/remotes.browser.js",
		"./dist/src/docker.js": "./dist/src/docker.browser.js",
		"./docker.js": "./dist/src/docker.browser.js",
		"./dist/src/aws.js": "./dist/src/aws.browser.js",
		"./dist/src/hetzner.js": "./dist/src/hetzner.browser.js"
	},
	"files": [
		"dist",
		"src",
		"src/nginx-template.conf",
		"!src/test",
		"!src/**/__tests__",
		"!lib/**/__tests__",
		"patches",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=18"
	},
	"eslintConfig": {
		"extends": "peerbit",
		"parserOptions": {
			"project": true,
			"sourceType": "module"
		},
		"ignorePatterns": [
			"!.aegir.js",
			"test/ts-use",
			"*.d.ts"
		]
	},
	"scripts": {
		"clean": "shx rm -rf lib/*",
		"build": "pnpm run clean && pnpm run build-lib && pnpm run build-ui",
		"build-lib": "tsc -p tsconfig.json",
		"build-ui": "pnpm --dir ../frontend build",
		"postbuild": "cp src/nginx-template.conf dist/src/ && cp -r ../frontend/dist/. dist/ui",
		"test": "aegir test --t node",
		"lint": "aegir lint",
		"test:cov": "aegir test -t node --cov"
	},
	"devDependencies": {
		"@peerbit/test-lib": "workspace:*",
		"@peerbit/test-utils": "workspace:*",
		"@types/libsodium-wrappers": "^0.7.14",
		"@types/tar-stream": "^3.1.3",
		"@types/tmp": "^0.2.3",
		"@types/yargs": "17.0.24",
		"aws-sdk": "^2.1259.0",
		"dotenv": "^16.1.4",
		"shx": "^0.3.4",
		"uuid": "^10.0.0"
	},
	"dependencies": {
		"@dao-xyz/borsh": "^6.0.0",
		"@libp2p/crypto": "^5.1.14",
		"@libp2p/interface": "^3.1.1",
		"@libp2p/peer-id": "^6.0.5",
		"@libp2p/tcp": "^11.0.14",
		"@libp2p/websockets": "^10.1.7",
		"@multiformats/multiaddr": "^13.0.1",
		"@peerbit/blocks": "workspace:*",
		"@peerbit/crypto": "workspace:*",
		"@peerbit/program": "workspace:*",
		"@peerbit/pubsub": "workspace:*",
		"@peerbit/time": "workspace:*",
		"abstract-level": "^3.1.0",
		"axios": "^1.4.0",
		"chalk": "^5.3.0",
		"level": "^10.0.0",
		"libsodium-wrappers": "0.7.15",
		"memory-level": "^3.1.0",
		"multiformats": "^13.4.2",
		"peerbit": "workspace:*",
		"tar-stream": "^3.1.7",
		"tmp": "^0.2.1",
		"tty-table": "^4.2.1",
		"uint8arrays": "^5.1.0",
		"yargs": "^17.7.2"
	},
	"optionalDependencies": {
		"@aws-sdk/client-ec2": "^3.390.0",
		"@aws-sdk/client-route-53": "^3.391.0"
	},
	"bugs": {
		"url": "https://github.com/dao-xyz/peerbit/issues"
	},
	"homepage": "https://github.com/dao-xyz/peerbit#readme"
}

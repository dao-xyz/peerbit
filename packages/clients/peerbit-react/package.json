{
	"name": "@peerbit/react",
	"version": "1.1.7",
	"description": "React bindings for Peerbit clients",
	"sideEffects": false,
	"type": "module",
	"types": "./dist/src/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"*",
				"dist/*",
				"dist/src/*",
				"dist/src/*/index"
			],
			"src/*": [
				"*",
				"dist/*",
				"dist/src/*",
				"dist/src/*/index"
			]
		}
	},
	"files": [
		"src",
		"dist",
		"!vitest",
		"!dist/vitest",
		"!**/*.tsbuildinfo"
	],
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"import": "./dist/src/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "aegir clean",
		"build": "aegir build --no-bundle",
		"test": "vitest run",
		"lint": "aegir lint",
		"test:cov": "vitest run --coverage"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	},
	"dependencies": {
		"@chainsafe/libp2p-noise": "^17.0.0",
		"@chainsafe/libp2p-yamux": "^8.0.1",
		"@dao-xyz/borsh": "^6.0.0",
		"@libp2p/circuit-relay-v2": "^4.1.7",
		"@libp2p/crypto": "^5.1.14",
		"@libp2p/interface": "^3.1.1",
		"@libp2p/webrtc": "^6.0.15",
		"@libp2p/websockets": "^10.1.7",
		"@multiformats/multiaddr": "^13.0.1",
		"@peerbit/canonical-client": "workspace:*",
		"@peerbit/crypto": "workspace:*",
		"@peerbit/indexer-interface": "workspace:*",
		"@peerbit/logger": "workspace:*",
		"@peerbit/program": "workspace:*",
		"@peerbit/program-react": "workspace:*",
		"debug": "^4.3.7",
		"detectincognitojs": "^1.6.1",
		"libsodium-wrappers": "0.7.15",
		"peerbit": "workspace:*",
		"uuid": "^10.0.0"
	},
	"devDependencies": {
		"@peerbit/time": "workspace:*",
		"@testing-library/dom": "^10.4.0",
		"@types/debug": "^4.1.12",
		"@types/libsodium-wrappers": "^0.7.14",
		"@types/node-localstorage": "^1.3.3",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.5",
		"@vitest/coverage-v8": "^4.0.12",
		"chai": "^5.2.0",
		"node-localstorage": "^3.0.5",
		"react-dom": "^19.1.0",
		"sinon": "^21.0.0",
		"vitest": "^4.0.12"
	},
	"author": "dao.xyz",
	"license": "MIT"
}

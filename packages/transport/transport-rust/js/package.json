{
  "name": "peerbit-transport-rust-js-listener",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Live-interop js-libp2p listener: Peerbit node transport spec (TCP+noise+yamux+identify), all three /peerbit/* multicodecs, decoding rust peerbit_wire envelopes with the real @peerbit/stream-interface codec.",
  "scripts": {
    "start": "node listener.mjs",
    "relay-js": "node relay-js.mjs",
    "relay-bench": "node relay-bench.mjs"
  },
  "dependencies": {
    "libp2p": "^3.1.7",
    "@libp2p/tcp": "^11.0.14",
    "@libp2p/circuit-relay-v2": "^4.1.7",
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@libp2p/identify": "^4.0.0",
    "@libp2p/crypto": "^5.1.14",
    "uint8arraylist": "^2.4.8",
    "it-length-prefixed": "^10.0.1",
    "it-pipe": "^3.0.1",
    "@peerbit/stream-interface": "file:../../stream-interface"
  }
}
